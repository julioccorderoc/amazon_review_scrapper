{
  "manifest_version": 3,
  "name": "Amazon Review Scraper",
  "version": "1.0",
  "description": "Click-to-scrape Amazon reviews into the local ingest server.",
  "permissions": ["storage", "tabs", "downloads", "scripting"],
  "host_permissions": [
    "*://*.amazon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Amazon Review Scraper",
    "default_popup": "popup.html"
  }
}
